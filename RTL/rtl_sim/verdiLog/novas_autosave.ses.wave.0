; Window Layout <x> <y> <width> <height> <signalwidth> <valuewidth>
viewPort 0 38 1920 811 100 65

; File list:
; openDirFile [-d delimiter] [-s time_offset] [-rf auto_bus_rule_file] path_name file_name
openDirFile -d / "" "/home/ICer/AES_ASIC/aes_ASIC/rtl_sim/wb_tb.fsdb"

; file time scale:
; fileTimeScale ### s|ms|us|ns|ps

; signal spacing:
signalSpacing 5

; windowTimeUnit is used for zoom, cursor & marker
; waveform viewport range
zoom 0.000000 1122120.100000
cursor 0.000000
marker 0.000000

; user define markers
; userMarker time_pos marker_name color linestyle
; visible top row signal index
top 0
; marker line index
markerPos 15

; event list
; addEvent event_name event_expression
; curEvent event_name



COMPLEX_EVENT_BEGIN


COMPLEX_EVENT_END



; toolbar current search type
; curSTATUS search_type
curSTATUS ByChange


addGroup "G1"
activeDirFile "" "/home/ICer/AES_ASIC/aes_ASIC/rtl_sim/wb_tb.fsdb"
addSignal -h 15 /wb_tb/d0[31:0]
addSignal -h 15 -holdScope d1[31:0]
addSignal -h 15 -holdScope d2[31:0]
addSignal -h 15 -holdScope d3[31:0]
addSignal -h 15 -holdScope status[31:0]
addSignal -h 15 -holdScope wb_ack
addSignal -h 15 -holdScope wb_adr[31:0]
addSignal -h 15 -holdScope wb_clk
addSignal -h 15 -holdScope wb_cyc
addSignal -h 15 -holdScope wb_dat_from_aes[31:0]
addSignal -h 15 -holdScope wb_dat_to_aes[31:0]
addSignal -h 15 -holdScope wb_rst
addSignal -h 15 -holdScope wb_sel[3:0]
addSignal -h 15 -holdScope wb_stb
addSignal -h 15 -holdScope wb_we
addGroup "G2"

; getSignalForm Scope Hierarchy Status
; active file of getSignalForm
activeDirFile "" "/home/ICer/AES_ASIC/aes_ASIC/rtl_sim/wb_tb.fsdb"

